# Omnifetch MCP server — environment configuration.
# Copy to .env and fill in as needed:  cp .env.example .env
#
# Server settings use the OMNIFETCH_ prefix; telemetry uses the standard
# OpenTelemetry OTEL_ variable names.

# --- Server ---
OMNIFETCH_TRANSPORT=stdio
OMNIFETCH_HOST=127.0.0.1
OMNIFETCH_PORT=8000
OMNIFETCH_LOG_LEVEL=INFO
OMNIFETCH_CACHE_BACKEND=memory
OMNIFETCH_REDIS_URL=
OMNIFETCH_DISK_CACHE_PATH=.cache/omnifetch
OMNIFETCH_HTTP_LIMIT_PER_HOST=20
OMNIFETCH_HTTP_TRANSIENT_RETRIES=0
OMNIFETCH_UVLOOP=auto
OMNIFETCH_REST_WEB_FETCH=true

# --- OpenTelemetry (opt-in; disabled while OTEL_TRACES_EXPORTER is empty) ---
# Set OTEL_TRACES_EXPORTER to `console` or `otlp` to enable tracing. Either
# exporter needs the optional extra:  uv sync --extra telemetry
OTEL_TRACES_EXPORTER=
OTEL_SERVICE_NAME=omnifetch-mcp
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SDK_DISABLED=false

# --- Fetch provider secrets ---
# Configure any subset; providers without secrets stay disabled.
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
JINA_API_KEY=
YOU_API_KEY=
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_ZONE=unblocker
LINKUP_API_KEY=
DIFFBOT_TOKEN=
SOCIAVAULT_API_KEY=
SPIDER_CLOUD_API_TOKEN=
SCRAPFLY_API_KEY=
SCRAPEGRAPHAI_API_KEY=
SCRAPE_DO_API_TOKEN=
SCRAPELESS_API_KEY=
OPENGRAPH_IO_API_KEY=
SCRAPINGBEE_API_KEY=
SCRAPERAPI_API_KEY=
ZYTE_API_KEY=
SCRAPINGANT_API_KEY=
OXYLABS_WEB_SCRAPER_USERNAME=
OXYLABS_WEB_SCRAPER_PASSWORD=
OLOSTEP_API_KEY=
# Must already be base64-encoded username:password.
DECODO_WEB_SCRAPING_API_KEY=
SCRAPPEY_API_KEY=
LEADMAGIC_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_KEY=
SERPAPI_API_KEY=
SUPADATA_API_KEY=
GITHUB_API_KEY=
KIMI_API_KEY=
