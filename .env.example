# Omnifetch MCP server — environment configuration.
# Copy to .env and fill in as needed:  cp .env.example .env
#
# Server settings use the OMNIFETCH_ prefix; telemetry uses the standard
# OpenTelemetry OTEL_ variable names.

# --- Server ---
OMNIFETCH_TRANSPORT=stdio
OMNIFETCH_HOST=127.0.0.1
OMNIFETCH_PORT=8000
OMNIFETCH_LOG_LEVEL=INFO

# --- OpenTelemetry (opt-in; disabled while OTEL_TRACES_EXPORTER is empty) ---
# Set OTEL_TRACES_EXPORTER to `console` or `otlp` to enable tracing. Either
# exporter needs the optional extra:  uv sync --extra telemetry
OTEL_TRACES_EXPORTER=
OTEL_SERVICE_NAME=omnifetch-mcp
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SDK_DISABLED=false
