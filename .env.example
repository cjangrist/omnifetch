# Omnifetch MCP server — environment configuration.
# Copy this file to `.env` and fill in values as needed:  cp .env.example .env
#
# Server settings use the OMNIFETCH_ prefix. Telemetry uses the standard
# OpenTelemetry OTEL_ variable names so the server interoperates with any
# OpenTelemetry collector or tooling out of the box.

# --- Server ----------------------------------------------------------------
OMNIFETCH_TRANSPORT=stdio
OMNIFETCH_HOST=127.0.0.1
OMNIFETCH_PORT=8000
OMNIFETCH_LOG_LEVEL=INFO
OMNIFETCH_STRICT_INPUT_VALIDATION=true
OMNIFETCH_MASK_ERROR_DETAILS=true

# --- OpenTelemetry (STUB) --------------------------------------------------
# Telemetry is DISABLED while OTEL_TRACES_EXPORTER is empty (zero overhead).
# To ENABLE tracing, set OTEL_TRACES_EXPORTER to one of: console | otlp
#   - console : print spans to stderr (great for local verification)
#   - otlp    : export to an OTLP collector at OTEL_EXPORTER_OTLP_ENDPOINT
# Enabling `otlp` requires the optional extra:  pip install 'omnifetch[telemetry]'
OTEL_TRACES_EXPORTER=
OTEL_SERVICE_NAME=omnifetch-mcp
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SDK_DISABLED=false
